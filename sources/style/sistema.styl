.sistema
    .content
        max-width 760px

        > .title
            text-align center
            margin-bottom 2rem

        .items
            display flex
            gap 30px

            @media only screen and (orientation portrait)
                flex-direction column

        .item
            display flex
            flex-direction column
            align-items center
            justify-content center
            position relative
            width 320px
            padding 20px 20px 30px 20px
            margin-bottom 30px
            text-align center
            padding-top 1.7rem
            border 1px solid #f0a89f
            border-top none

            @media only screen and (orientation portrait)
                width auto

            .title-container
                display flex
                position absolute
                top 0
                left 0
                right 0
                height 0
                align-items center
                gap 10px

                .line
                    flex 1
                    height 1px
                    background #f0a89f

                .title
                    flex 1
                    font-size 1.7rem
                    color #f0a89f
                    white-space nowrap
                    margin-bottom 0
